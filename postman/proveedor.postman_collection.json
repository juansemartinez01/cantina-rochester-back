{
  "info": {
    "_postman_id": "8b7f6035-bd9e-4f5d-8ce0-proveedor-crud",
    "name": "Gestion Stock - Proveedor Module",
    "description": "Coleccion para probar los endpoints del modulo Proveedor. Configurar baseUrl y token antes de ejecutar los requests protegidos.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "proveedorId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "usuario",
      "value": "",
      "type": "string"
    },
    {
      "key": "password",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth - Login opcional",
      "item": [
        {
          "name": "POST /auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login responde 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.collectionVariables.set('token', json.access_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usuario\": \"{{usuario}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Request opcional para obtener JWT. Completar variables usuario y password. Si responde access_token, lo guarda en la variable token."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Proveedor",
      "item": [
        {
          "name": "GET /proveedores",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Respuesta es array', function () {",
                  "  pm.expect(pm.response.json()).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/proveedores",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "proveedores"
              ]
            },
            "description": "Lista todos los proveedores."
          },
          "response": []
        },
        {
          "name": "POST /proveedores",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201 o 200', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Respuesta incluye id', function () {",
                  "  pm.expect(json).to.have.property('id');",
                  "});",
                  "",
                  "if (json.id) {",
                  "  pm.collectionVariables.set('proveedorId', String(json.id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Proveedor Test {{$timestamp}}\",\n  \"contacto\": \"Contacto Test\",\n  \"telefono\": \"1122334455\",\n  \"email\": \"proveedor{{$timestamp}}@mail.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/proveedores",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "proveedores"
              ]
            },
            "description": "Crea un proveedor y guarda el id en la variable proveedorId."
          },
          "response": []
        },
        {
          "name": "GET /proveedores/:id",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Respuesta corresponde al proveedorId', function () {",
                  "  pm.expect(String(json.id)).to.eql(pm.collectionVariables.get('proveedorId'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/proveedores/{{proveedorId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "proveedores",
                "{{proveedorId}}"
              ]
            },
            "description": "Obtiene un proveedor por id."
          },
          "response": []
        },
        {
          "name": "PUT /proveedores/:id",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Actualiza contacto', function () {",
                  "  pm.expect(json.contacto).to.eql('Contacto Actualizado');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Proveedor Test Actualizado {{$timestamp}}\",\n  \"contacto\": \"Contacto Actualizado\",\n  \"telefono\": \"1199998888\",\n  \"email\": \"proveedor.actualizado{{$timestamp}}@mail.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/proveedores/{{proveedorId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "proveedores",
                "{{proveedorId}}"
              ]
            },
            "description": "Actualiza parcialmente un proveedor. El body puede enviar uno o varios campos."
          },
          "response": []
        },
        {
          "name": "DELETE /proveedores/:id",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200, 204 o conflicto por referencias', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 204, 409, 500]);",
                  "});",
                  "",
                  "if (pm.response.code === 409 || pm.response.code === 500) {",
                  "  console.warn('El proveedor puede tener referencias asociadas. Hoy el backend no valida todas las referencias antes de borrar.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/proveedores/{{proveedorId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "proveedores",
                "{{proveedorId}}"
              ]
            },
            "description": "Elimina fisicamente un proveedor por id. Usar preferentemente con un proveedor creado por esta coleccion."
          },
          "response": []
        },
        {
          "name": "GET /proveedores/:id - 404 esperado",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 404', function () {",
                  "  pm.response.to.have.status(404);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/proveedores/999999999",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "proveedores",
                "999999999"
              ]
            },
            "description": "Caso negativo para validar proveedor inexistente."
          },
          "response": []
        }
      ]
    }
  ]
}
